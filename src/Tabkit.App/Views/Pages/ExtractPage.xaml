<Page
    x:Class="Tabkit.App.Views.Pages.ExtractPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Tabkit.App.ViewModels.Pages"
    xmlns:controls="clr-namespace:Tabkit.App.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance vm:ExtractViewModel}"
    mc:Ignorable="d"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar: path + load/save + actions -->
        <ui:Card Grid.Row="0" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Pipeline:" />

                <TextBox
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    IsReadOnly="True"
                    FontFamily="Consolas"
                    Text="{Binding PipelinePath}" />

                <ui:Button
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Icon="{ui:SymbolIcon Open24}"
                    Content="Load..."
                    Visibility="{Binding IsVisibleLoadSaveValidate, Converter={StaticResource BoolToVisibility}}"
                    Command="{Binding LoadCommand}" />
                <ComboBox
                    x:Name="RecentsCombo"
                    Grid.Column="3"
                    Margin="4,0,0,0"
                    Width="42"
                    ToolTip="Recent pipelines"
                    ItemsSource="{Binding RecentPipelines}"
                    SelectedIndex="-1"
                    Visibility="{Binding IsVisibleLoadSaveValidate, Converter={StaticResource BoolToVisibility}}"
                    SelectionChanged="OnRecentSelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ui:Button
                    Grid.Column="4"
                    Margin="8,0,0,0"
                    Icon="{ui:SymbolIcon Save24}"
                    Content="Save..."
                    Visibility="{Binding IsVisibleLoadSaveValidate, Converter={StaticResource BoolToVisibility}}"
                    Command="{Binding SaveCommand}" />
                <ui:Button
                    Grid.Column="5"
                    Margin="16,0,0,0"
                    Icon="{ui:SymbolIcon Checkmark24}"
                    Content="Validate"
                    Visibility="{Binding IsVisibleLoadSaveValidate, Converter={StaticResource BoolToVisibility}}"
                    Command="{Binding ValidateCommand}" />
                <ui:Button
                    Grid.Column="6"
                    Margin="8,0,0,0"
                    Appearance="Primary"
                    Icon="{ui:SymbolIcon Play24}"
                    Content="Run"
                    Visibility="{Binding IsVisibleRun, Converter={StaticResource BoolToVisibility}}"
                    Command="{Binding RunCommand}" />
                <!--
                    Cancel stays visible-but-disabled (CanCancelRun gates IsEnabled) per
                    WPF-UI Gallery operation-control convention. Hiding leaves the user
                    without visual confirmation that a stop control exists.
                -->
                <ui:Button
                    Grid.Column="7"
                    Margin="8,0,0,0"
                    Icon="{ui:SymbolIcon Dismiss24}"
                    Content="Cancel"
                    Command="{Binding CancelRunCommand}" />
            </Grid>
        </ui:Card>

        <!-- YAML editor -->
        <ui:Card Grid.Row="1" Padding="0">
            <TextBox
                Text="{Binding YamlText, UpdateSourceTrigger=PropertyChanged}"
                AcceptsReturn="True"
                AcceptsTab="True"
                IsReadOnly="{Binding IsRunning}"
                FontFamily="Consolas"
                FontSize="13"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto"
                BorderThickness="0"
                Background="Transparent"
                Padding="12" />
        </ui:Card>

        <!-- Validation strip -->
        <Border
            Grid.Row="2"
            Margin="0,8,0,0"
            Padding="12,8"
            CornerRadius="4"
            Background="{DynamicResource ControlFillColorSecondaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center">
                    <Run Text="✓" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                         FontWeight="Bold" />
                </TextBlock>
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                    Text="{Binding ValidationMessage}" />

            </Grid>
        </Border>

        <!-- Result panel (visible only after a successful run) -->
        <ui:Card
            Grid.Row="3"
            Margin="0,8,0,0"
            Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Margin="0,0,18,0">
                        <Run Text="Pipeline: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Run Text="{Binding ResultName, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock Grid.Column="1" Margin="0,0,18,0">
                        <Run Text="Rows in: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Run Text="{Binding RowsIn, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock Grid.Column="2" Margin="0,0,18,0">
                        <Run Text="Rows out: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Run Text="{Binding RowsOut, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock Grid.Column="3" Margin="0,0,18,0">
                        <Run Text="Transforms: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Run Text="{Binding TransformsApplied, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock Grid.Column="4" Margin="0,0,18,0">
                        <Run Text="Duration: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Run Text="{Binding DurationDisplay, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                </Grid>
                <TextBlock
                    Grid.Row="1"
                    Margin="0,4,0,0"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run Text="Output: " />
                    <Run Text="{Binding ResultOutputPath, Mode=OneWay}" FontFamily="Consolas" />
                </TextBlock>
                <TextBlock
                    Grid.Row="2"
                    Margin="0,4,0,0"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run Text="Columns: " />
                    <Run Text="{Binding ColumnsDisplay, Mode=OneWay}" FontFamily="Consolas" />
                </TextBlock>
            </Grid>
        </ui:Card>

        <!-- Status bar -->
        <Border
            Grid.Row="4"
            Margin="0,8,0,0"
            Padding="12,8"
            CornerRadius="4"
            Background="{DynamicResource ControlFillColorSecondaryBrush}">
            <TextBlock
                Text="{Binding StatusMessage}"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>

        <!-- Brand async progress overlay (covers content during pipeline runs) -->
        <controls:BusyOverlay
            Grid.Row="0"
            Grid.RowSpan="5"
            IsBusy="{Binding IsRunning}"
            Title="Running pipeline..."
            Step="{Binding StatusMessage}" />
    </Grid>
</Page>
