<?xml version='1.0' encoding='utf-8' ?>
<!--
  Pathological: field with a 1000+ character name and a calculated field
  that references it. Exercises the loader's attribute-value handling and
  the column-ref regex `\[[^\[\]\r\n]+\]` (must match the full bracketed
  name without truncation). Calc must parse and the loader must preserve
  the full name in Field.Name.
-->
<workbook source-build='2024.3.0' source-platform='win' version='18.1'>
  <datasources>
    <datasource caption='LongNames' name='federated.longnames' version='18.1'>
      <connection class='excel-direct' filename='longnames.xlsx'/>
      <column datatype='real' name='[]' role='measure' type='quantitative'/>
      <column datatype='real' name='[ref_long]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[] + 1'/>
      </column>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Sheet'>
      <table><view><datasources><datasource name='federated.longnames'/></datasources></view></table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name='Main'>
      <zones>
        <zone id='1' type='layout-basic'>
          <zone id='2' name='Sheet' type='worksheet'/>
        </zone>
      </zones>
    </dashboard>
  </dashboards>
</workbook>
