<?xml version='1.0' encoding='utf-8' ?>
<!--
  Fires GOV002 exactly once: server is outside the default allowlist
  (not localhost / 127.0.0.1 / *.internal.example.com).
-->
<workbook source-build='2024.3.0' source-platform='win' version='18.1'>
  <datasources>
    <datasource caption='External DB' name='federated.external' version='18.1'>
      <connection class='sqlserver' server='vendor-prod.example.net' dbname='analytics' username='svc'/>
      <column datatype='integer' name='[order_id]' role='dimension' type='ordinal'/>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Sheet'>
      <table><view><datasources><datasource name='federated.external'/></datasources></view></table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name='Main'>
      <zones>
        <zone id='1' type='layout-basic'>
          <zone id='2' name='Sheet' type='worksheet'/>
        </zone>
      </zones>
    </dashboard>
  </dashboards>
</workbook>
