<?xml version='1.0' encoding='utf-8' ?>
<!--
  Fires AUD003 exactly once: calc uses deprecated ATTR().
  All column references are valid so AUD005 doesn't misfire.
-->
<workbook source-build='2024.3.0' source-platform='win' version='18.1'>
  <datasources>
    <datasource caption='Orders' name='federated.orders' version='18.1'>
      <connection class='excel-direct' filename='orders.xlsx'/>
      <column datatype='string' name='[region]' role='dimension' type='nominal'/>
      <column datatype='string' name='[region_attr]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='ATTR([region])'/>
      </column>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Sheet'>
      <table><view><datasources><datasource name='federated.orders'/></datasources></view></table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name='Main'>
      <zones>
        <zone id='1' type='layout-basic'>
          <zone id='2' name='Sheet' type='worksheet'/>
        </zone>
      </zones>
    </dashboard>
  </dashboards>
</workbook>
