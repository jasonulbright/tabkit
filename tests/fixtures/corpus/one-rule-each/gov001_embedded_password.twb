<?xml version='1.0' encoding='utf-8' ?>
<!--
  Fires GOV001 exactly once: connection carries an embedded password.
  Server is on the localhost allowlist so GOV002 doesn't fire.
  No PII field names so GOV003 doesn't fire. No USERNAME() calc so GOV004
  doesn't fire. Server-based (not filename) so GOV005 doesn't fire.
-->
<workbook source-build='2024.3.0' source-platform='win' version='18.1'>
  <datasources>
    <datasource caption='Local DB' name='federated.local' version='18.1'>
      <connection class='sqlserver' server='localhost' dbname='analytics' username='svc' password='REDACTED'/>
      <column datatype='integer' name='[order_id]' role='dimension' type='ordinal'/>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Sheet'>
      <table><view><datasources><datasource name='federated.local'/></datasources></view></table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name='Main'>
      <zones>
        <zone id='1' type='layout-basic'>
          <zone id='2' name='Sheet' type='worksheet'/>
        </zone>
      </zones>
    </dashboard>
  </dashboards>
</workbook>
