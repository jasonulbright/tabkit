<?xml version='1.0' encoding='utf-8' ?>
<!--
  Fires AUD006 exactly once: version='17.0' falls below the 18.0 floor.
-->
<workbook source-build='2020.4.0' source-platform='win' version='17.0'>
  <datasources>
    <datasource caption='Orders' name='federated.orders' version='17.0'>
      <connection class='excel-direct' filename='orders.xlsx'/>
      <column datatype='integer' name='[order_id]' role='dimension' type='ordinal'/>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Sheet'>
      <table><view><datasources><datasource name='federated.orders'/></datasources></view></table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name='Main'>
      <zones>
        <zone id='1' type='layout-basic'>
          <zone id='2' name='Sheet' type='worksheet'/>
        </zone>
      </zones>
    </dashboard>
  </dashboards>
</workbook>
